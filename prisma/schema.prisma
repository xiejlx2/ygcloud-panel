// Prisma Schema for 服务器控制台
// 默认使用 SQLite（MVP 本地零依赖启动）。
// 切换 PostgreSQL：将下方 provider 改为 "postgresql"，并把 .env 中的
// DATABASE_URL 改为 postgresql 连接串即可。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== 1. 用户表：代理商主账号 + 客户子账号 =====
model User {
  id           String    @id @default(cuid())
  // 客户所属代理商；代理商主账号自身该字段为 null
  parentId     String?   @map("parent_id")
  parent       User?     @relation("CustomerToReseller", fields: [parentId], references: [id], onDelete: Restrict)
  customers    User[]    @relation("CustomerToReseller")

  // reseller_admin | customer
  role         String
  username     String    @unique
  passwordHash String    @map("password_hash")
  displayName  String    @map("display_name")
  // active | disabled
  status       String    @default("active")
  // 会话版本：签入 JWT，重置密码时 +1，使该用户所有旧会话立即失效
  tokenVersion Int       @default(0) @map("token_version")
  // 是否允许该客户自助重装系统（破坏性操作，默认关闭，由代理商按客户开启）
  canReinstall Boolean   @default(false) @map("can_reinstall")
  remark       String?
  phone        String?
  email        String?
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  apiTokens           ResellerApiToken[]
  // 作为代理商拥有的服务器分配记录
  assignmentsAsReseller ServerAssignment[] @relation("AssignmentReseller")
  // 作为客户被分配的服务器记录
  assignmentsAsCustomer ServerAssignment[] @relation("AssignmentCustomer")
  // 作为代理商维度的日志
  logsAsReseller      OperationLog[] @relation("LogReseller")
  // 作为操作者本人的日志
  logsAsUser          OperationLog[] @relation("LogUser")
  // 代理商拥有的服务器缓存
  serverCache         ServerCache[] @relation("ServerCacheOwner")
  // 代理商已知地域表
  knownZones          ResellerKnownZone[] @relation("KnownZoneOwner")
  // 代理商通知渠道配置
  notifyConfig        ResellerNotifyConfig? @relation("NotifyConfigOwner")

  @@index([parentId])
  @@map("users")
}

// ===== 2. 代理商 API Token（加密存储，绝不出前端）=====
model ResellerApiToken {
  id             String    @id @default(cuid())
  resellerId     String    @unique @map("reseller_id")
  reseller       User      @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  tokenEncrypted String    @map("token_encrypted")
  // 用于校验密钥是否变化导致无法解密
  tokenKeyHint   String?   @map("token_key_hint")
  // active | invalid | revoked
  status         String    @default("active")
  // 仅展示用：返回后 4 位
  tokenSuffix    String?   @map("token_suffix")
  lastVerifiedAt DateTime? @map("last_verified_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("reseller_api_tokens")
}

// ===== 2.5 代理商“已知地域”表 =====
// 记录该代理商曾经有过机器的 (地域, 可用区)。用途：
//   上游 /region/list 只返回“当前在售”地域，已售罄下架的地域会消失，
//   但其存量机器仍在运行、instance/list 仍可查。日常同步遍历
//   “在售地域 ∪ 本表已知地域”，即可覆盖这类下架地域的机器（不再漏同步）。
// 只由「更新地域库」按钮写入（只增不删），日常同步只读不写。
model ResellerKnownZone {
  id          String   @id @default(cuid())
  resellerId  String   @map("reseller_id")
  reseller    User     @relation("KnownZoneOwner", fields: [resellerId], references: [id], onDelete: Cascade)
  regionCode  String   @map("region_code")
  regionName  String?  @map("region_name")
  zoneCode    String   @map("zone_code")
  zoneName    String?  @map("zone_name")
  // 上次「更新地域库」时观测到的机器数（诊断用）
  machineCount Int     @default(0) @map("machine_count")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([resellerId, regionCode, zoneCode])
  @@index([resellerId])
  @@map("reseller_known_zones")
}

// ===== 3. 服务器本地缓存（来自上游 /instance/list）=====
model ServerCache {
  id                String    @id @default(cuid())
  resellerId        String    @map("reseller_id")
  reseller          User      @relation("ServerCacheOwner", fields: [resellerId], references: [id], onDelete: Cascade)
  ecsResourceUuid   String    @map("ecs_resource_uuid")
  instanceName      String?   @map("instance_name")
  publicIpAddress   String?   @map("public_ip_address")
  internalIpAddress String?   @map("internal_ip_address")
  regionCode        String?   @map("region_code")
  regionName        String?   @map("region_name")
  zoneCode          String?   @map("zone_code")
  zoneName          String?   @map("zone_name")
  cpu               Int?
  memory            Int?
  bandwidth         Int?
  osName            String?   @map("os_name")
  osVersionDetail   String?   @map("os_version_detail")
  ecsStatus         String?   @map("ecs_status")
  ecsPendingStatus  String?   @map("ecs_pending_status")
  expireTime        DateTime? @map("expire_time")
  // 本地别名/备注（面板内自定义，不回写上游；同步不覆盖，因上游 payload 不含这些字段）
  customerAlias     String?   @map("customer_alias")
  customerNote      String?   @map("customer_note")
  rawJson           String?
  lastSyncedAt      DateTime  @default(now()) @map("last_synced_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  assignments       ServerAssignment[]

  @@unique([resellerId, ecsResourceUuid])
  @@index([resellerId])
  @@map("server_cache")
}

// ===== 4. 服务器分配关系：一台服务器同时只能分给一个客户 =====
model ServerAssignment {
  id              String    @id @default(cuid())
  resellerId      String    @map("reseller_id")
  reseller        User      @relation("AssignmentReseller", fields: [resellerId], references: [id], onDelete: Cascade)
  customerId      String    @map("customer_id")
  customer        User      @relation("AssignmentCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  ecsResourceUuid String    @map("ecs_resource_uuid")
  server          ServerCache? @relation(fields: [resellerId, ecsResourceUuid], references: [resellerId, ecsResourceUuid], onDelete: Restrict)
  // active | revoked
  status          String    @default("active")
  assignedAt      DateTime  @default(now()) @map("assigned_at")
  unassignedAt    DateTime? @map("unassigned_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([resellerId, ecsResourceUuid])
  @@index([customerId])
  @@map("server_assignments")
}

// ===== 5. 操作日志 =====
model OperationLog {
  id              String    @id @default(cuid())
  resellerId      String    @map("reseller_id")
  reseller        User      @relation("LogReseller", fields: [resellerId], references: [id], onDelete: Cascade)
  userId          String    @map("user_id")
  user            User      @relation("LogUser", fields: [userId], references: [id], onDelete: Cascade)
  userRole        String    @map("user_role")
  ecsResourceUuid String    @map("ecs_resource_uuid")
  // start | stop | restart | modify_password | sync_server | assign_server | unassign_server | login | ...
  action          String
  requestPayload  String?
  asyncTaskUuid   String?   @map("async_task_uuid")
  // PENDING | FINISHED | FAILED | UNKNOWN
  taskStatus      String?   @map("task_status")
  // SUCCESS | FAILED | null（无异步任务时）
  processResult   String?   @map("process_result")
  errMsg          String?   @map("err_msg")
  requestIp       String?   @map("request_ip")
  userAgent       String?   @map("user_agent")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([resellerId, createdAt])
  @@index([userId, createdAt])
  @@index([ecsResourceUuid])
  @@map("operation_logs")
}

// ===== 6. 代理商通知渠道配置 =====
// 每个代理商一条。bot token / webhook url 含密钥，AES-256-GCM 加密存储（见 lib/crypto.ts），
// 任何前端接口都不返回明文，仅展示后 4 位与密钥指纹。chat id 非敏感，明文存。
model ResellerNotifyConfig {
  id                        String    @id @default(cuid())
  resellerId                String    @unique @map("reseller_id")
  reseller                  User      @relation("NotifyConfigOwner", fields: [resellerId], references: [id], onDelete: Cascade)
  enabled                   Boolean   @default(true)
  // Telegram
  telegramBotTokenEncrypted String?   @map("telegram_bot_token_encrypted")
  telegramTokenSuffix       String?   @map("telegram_token_suffix")
  telegramKeyHint           String?   @map("telegram_key_hint")
  telegramChatId            String?   @map("telegram_chat_id")
  // 企业 webhook：wecom | dingtalk | feishu
  webhookType               String?   @map("webhook_type")
  webhookUrlEncrypted       String?   @map("webhook_url_encrypted")
  webhookKeyHint            String?   @map("webhook_key_hint")
  // 诊断
  lastRunAt                 DateTime? @map("last_run_at")
  lastError                 String?   @map("last_error")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  @@map("reseller_notify_configs")
}

// ===== 7.5 面板品牌设置（白标）=====
// 实例级单行配置（id 固定 "default"）。全部字段可空：空 = 使用内置默认品牌
// （菱形标 +「服务器控制台」）。将来若做多代理商 SaaS，可升级为按代理商/域名一行。
model PanelSetting {
  id            String   @id @default("default")
  // 面板名称：顶栏、登录页、浏览器标题、通知消息前缀
  panelName     String?  @map("panel_name")
  // Logo：data URL（data:image/...;base64,...），上传时校验类型与大小
  logoDataUrl   String?  @map("logo_data_url")
  // 登录页副标题（品牌下方一行小字，可放口号/公司名）
  loginSubtitle String?  @map("login_subtitle")
  // 主题色（#RRGGBB，对应色板 600 位基色）：按钮/导航高亮/聚焦态等全站跟随；
  // 空 = 默认靛蓝。色阶派生见 lib/theme.ts
  themeColor    String?  @map("theme_color")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("panel_settings")
}

// ===== 7. 通知发送记录（去重 + 历史）=====
// 每条告警发送前先按 (resellerId, dedupKey) 查重，命中则跳过，避免重复轰炸。
// dedupKey 规则见 lib/notifyScan.ts。
model NotificationLog {
  id         String   @id @default(cuid())
  resellerId String   @map("reseller_id")
  dedupKey   String   @map("dedup_key")
  // expiry | recycle | token
  kind       String
  // 实际送达渠道，逗号分隔（telegram,wecom…）
  channels   String?
  success    Boolean  @default(true)
  detail     String?
  sentAt     DateTime @default(now()) @map("sent_at")

  @@unique([resellerId, dedupKey])
  @@index([resellerId, sentAt])
  @@map("notification_logs")
}
