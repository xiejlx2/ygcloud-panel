# ===== 服务器控制台 环境变量样例 =====
# 复制为 .env 并填写真实值。生产环境务必使用强随机密钥。

# 上游云平台 OpenAPI 基础地址（不含具体路径）。必填，由部署方提供。
PROVIDER_API_BASE=https://your-provider-openapi.example.com

# 镜像列表中需要屏蔽的关键词（逗号分隔，命中名称/系统字段即隐藏）。
# 用于隐去带上游服务商标识的镜像；留空则不过滤。
IMAGE_HIDE_KEYWORDS=

# 额外同步地域（可选）。上游 region/list 不含已售罄下架的地域，但这些地域的
# 存量机器仍在运行、instance/list 仍可查到。把这类地域码在此手动补上，同步时并入，
# 否则其机器会被漏同步。
# 格式：逗号分隔多个，每个为 "regionCode:zoneCode"；省略 zoneCode 时默认 regionCode+"-a"。
# 例：EXTRA_SYNC_ZONES="sau-jeddah-1:sau-jeddah-1-a"
EXTRA_SYNC_ZONES=

# 接入凭据加密密钥：32 字节随机串的 hex（共 64 个十六进制字符）。
# 生成方法：openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=replace-with-random-32-bytes-hex

# JWT 签名密钥：长随机串。
# 生成方法：openssl rand -hex 48
JWT_SECRET=replace-with-strong-random-jwt-secret

# JWT 有效期（小时）
JWT_EXPIRES_HOURS=12

# 是否信任反向代理注入的客户端 IP 头（x-forwarded-for / x-real-ip / cf-connecting-ip）。
# 这些头客户端可伪造，用于绕过 IP 维度限流。
# - 部署在可信反代（Nginx / Caddy / Cloudflare 等，会重写这些头）之后：设为 true。
# - 直连暴露（无可信反代）：保持 false / 不设置，避免伪造头绕过限流。
#
# ⚠ 重要：登录限流依赖客户端 IP。取不到 IP 时会降级为“用户名维度 + 全局宽松兜底”，
# 防爆破能力明显减弱，且攻击者可针对已知用户名制造锁定。
# 生产环境务必部署在可信反代之后并设置 TRUST_PROXY_HEADERS=true。
TRUST_PROXY_HEADERS=false

# 会话 cookie 是否强制 Secure（仅 HTTPS 传输）。生产默认 true。
# 仅当确实部署在纯 HTTP（如直接用 IP 访问、未配 HTTPS）时才设为 false，
# 且需明确知道此时会话 cookie 可能被网络嗅探。
# COOKIE_SECURE=true

# 数据库连接。
# SQLite（默认，零依赖本地启动）：
DATABASE_URL="file:./dev.db"
# PostgreSQL（生产环境推荐）：
# DATABASE_URL="postgresql://user:password@localhost:5432/panel?schema=public"

# 初始管理员主账号（仅在 seed 脚本运行时使用，便于首次登录）。
# 生产环境请改为强随机密码（默认弱口令会被 seed 拒绝）。
SEED_RESELLER_USERNAME=admin
SEED_RESELLER_PASSWORD=Admin@12345
SEED_RESELLER_DISPLAY_NAME=管理员

# 服务端监听端口（可选）
PORT=3000

# 定时同步+通知任务的调用密钥（可选，但强烈建议配置：否则无每日自动同步，缓存会过期）。
# 调度器（crontab 或 systemd timer）定时 curl POST /api/cron/notify 并带 x-cron-secret 头，
# 值与此一致才会执行；未设置则该端点返回 503。
# 任务行为：对所有代理商做一次真实同步（保持数据新鲜）；对配好通知渠道的代理商
# 扫描到期/回收站/凭据失效并推送（已去重，跑得频繁也不会重复告警）。
# 推荐频率：每小时一次（如 systemd timer OnCalendar=*-*-* *:07:00）。
# 生成方法：openssl rand -hex 24
# crontab 示例（每小时第 7 分）：
#   7 * * * * curl -s -X POST http://127.0.0.1:3000/api/cron/notify -H "x-cron-secret: <值>" >> /var/log/notify-cron.log 2>&1
CRON_SECRET=
